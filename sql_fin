Customers table ke tamam records show karo.
SELECT *  
FROM Customers;
Sirf CustomerName show karo.
SELECT  CustomerName 
FROM Customers;
Unique cities show karo.
SELECT  DISTINCT(City) 
FROM Customers;
Karachi ke customers show karo.
SELECT *  
FROM Customers 
WHERE City = 'Karachi';
Lahore ke customers show karo.
SELECT *  
FROM Customers 
WHERE City = 'Lahore';
Age 25 se zyada customers show karo.
SELECT *  
FROM Customers 
WHERE Age > 25;
Customers ko CustomerName ke mutabiq sort karo.
SELECT *  
FROM Customers 
ORDER BY CustomerName ASC;
Customers ko Age descending me sort karo.
SELECT *  
FROM Customers 
ORDER BY Age DESC;
Products table ke tamam records show karo.
SELECT *  
FROM Products;
ProductName aur Price show karo.
SELECT ProductName,Price 
FROM Products;
10000 se zyada price wale products show karo.
SELECT *  
FROM Products 
WHERE Price > 10000;
Sab se mehnga product show karo.
SELECT MAX(Price) 
FROM Products;
Sab se sasta product show karo.
SELECT MIN(Price) 
FROM Products;
Total products count karo.
SELECT COUNT(ProductID) 
FROM Products;
Average product price show karo.
SELECT AVG(Price) 
FROM Products;
Employees table ke tamam records show karo.
SELECT * 
FROM Employees;
60000 se zyada salary wale employees show karo.
SELECT * 
FROM employees 
WHERE Salary > 60000;
Employees ko salary descending me show karo.
SELECT * 
FROM employees 
ORDER BY Salary DESC ;
Total employees count karo.
SELECT COUNT(EmployeeID) 
FROM  Employees;
Average salary show karo.
SELECT AVG(Salary) 
FROM Employees;
Jin customers ka naam A se start hota hai show karo.
SELECT * 
FROM Customers  
WHERE CustomerName LIKE 'A%';
Jin customers ka naam a par end hota hai show karo.
SELECT * 
FROM Customers  
WHERE CustomerName LIKE '%a';
Karachi ya Lahore ke customers show karo.
SELECT * 
FROM Customers  
WHERE City IN ('Karachi','Lahore');
Karachi ke ilawa tamam customers show karo.
SELECT * 
FROM Customers  
WHERE City != 'Karachi';
Age 22 aur 28 ke darmiyan customers show karo.departments.
SELECT * 
FROM Customers  
WHERE Age BETWEEN 22 AND 28;
Employees jo Karachi me hain aur salary 60000 se zyada hai.
SELECT * 
FROM Employees 
WHERE City = 'Karachi' AND Salary > 60000; 
Products jinki price 2000 aur 30000 ke darmiyan hai.
SELECT * 
FROM Products 
WHERE Price BETWEEN 2000 AND 30000;
Customers table ko alias C de kar records show karo.
SELECT * 
FROM Customers AS C;
Employees table ko alias E de kar records show karo.
SELECT * 
FROM Employees AS E;
Har city ke customers count karo.
SELECT City,COUNT(CustomerID) 
FROM Customers 
GROUP BY City;
Har city ki average salary show karo.
SELECT City,AVG(Salary) 
FROM Employees 
GROUP BY City;
Har customer ke orders count karo.
SELECT Customers.CustomerName,COUNT(Orders.OrderID) 
FROM Customers 
JOIN Orders 
ON Customers.CustomerID =  Orders.CustomerID 
GROUP BY Customers.CustomerName ;
Total order amount calculate karo.
SELECT SUM(Amount) 
FROM Orders;
Average order amount calculate karo.
SELECT AVG(Amount) 
FROM Orders;
