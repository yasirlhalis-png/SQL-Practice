Salary ke hisab se employees ko ascending order me show karo.
SELECT * 
FROM Employees 
ORDER BY salary ASC;
Price ke hisab se top 3 products show karo.
SELECT *  
FROM Products 
ORDER BY Price DESC LIMIT 3; 
Customers aur Orders ka INNER JOIN lagao.
SELECT * 
FROM Customers 
INNER JOIN Orders 
ON Customers.CustomerID =Orders.CustomerID; 
Customers aur Orders ka LEFT JOIN lagao.
SELECT * 
FROM Customers 
LEFT JOIN Orders 
ON Customers.CustomerID =Orders.CustomerID; 
Customers aur Orders ka RIGHT JOIN lagao.
SELECT * 
FROM Customers 
RIGHT JOIN Orders 
ON Customers.CustomerID =Orders.CustomerID; 
Customers aur Orders ka FULL JOIN lagao.
SELECT * 
FROM Customers 
FULL JOIN Orders 
ON Customers.CustomerID =Orders.CustomerID; 
Har customer ka naam aur uski total order amount show karo (GROUP BY).
SELECT Customers.CustomerName,SUM(Orders.Amount) AS Total_Order 
FROM Customers 
JOIN Orders 
ON Customers.CustomerID = Orders.CustomerID 
GROUP BY Customers.CustomerName; 
Sirf un customers ko show karo jinki total order amount 2000 se zyada hai (HAVING).
SELECT Customers.CustomerName,SUM(Orders.Amount) AS Total_Order 
FROM Customers 
JOIN Orders 
ON Customers.CustomerID = Orders.CustomerID 
GROUP BY Customers.CustomerName 
HAVING SUM(Orders.Amount) > 2000; 
Jin customers ne order diya hai unko show karo (EXISTS).
SELECT * 
FROM Customers 
WHERE EXISTS (SELECT * 
FROM   Orders 
WHERE Customers.CustomerID = Orders.CustomerID);
Jin customers ne koi order nahi diya unko show karo (NOT EXISTS).
SELECT * 
FROM Customers 
WHERE NOT EXISTS (SELECT * 
FROM  Orders 
WHERE Customers.CustomerID = Orders.CustomerID);
Orders show karo jinki amount CustomerID = 1  ke kisi bhi order amount se zyada hai (ANY).
SELECT * 
FROM  Orders 
WHERE Amount > ANY (SELECT Amount 
FROM  Orders WHERE CustomerID = 1);   
Orders show karo jinki amount CustomerID = 1 ke tamam order amounts se zyada hai (ALL).
SELECT * 
FROM  Orders 
WHERE Amount > ALL (SELECT Amount 
FROM  Orders WHERE CustomerID = 1); 
Customers aur Employees ke cities ko UNION se show karo.
SELECT City FROM Customers
UNION
SELECT City FROM Employees;
Customers aur Employees ke cities ko UNION ALL se show karo.
SELECT City FROM Customers
UNION ALL
SELECT City FROM Employees;
Har city me kitne employees hain (GROUP BY).
SELECT City,COUNT(EmployeeName) AS Total_Employees 
FROM Employees 
GROUP BY City;
Har city me 1 se zyada employees wali cities show karo (HAVING).
SELECT City,COUNT(EmployeeName) AS Total_Employees 
FROM Employees 
GROUP BY City 
HAVING Count(EmployeeName) > 1;